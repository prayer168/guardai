# mock：不需要 API Key；live：在伺服器端嘗試使用 OpenAI，失敗會回退 Mock。
GUARDAI_AI_MODE=mock

# 僅在 GUARDAI_AI_MODE=live 時需要。請勿提交真實金鑰。
OPENAI_API_KEY=

# 必須是帳戶可使用且支援 Structured Outputs 的模型。
OPENAI_MODEL=gpt-5.6-luna

# 單次即時 AI 最長等待時間，範圍 5,000–45,000 毫秒。
GUARDAI_AI_TIMEOUT_MS=20000

# 臺北時間每日全站與單一訪客的即時 AI 上限；超過後安全回退 Mock。
GUARDAI_DAILY_LIMIT=200
GUARDAI_VISITOR_DAILY_LIMIT=40

# 限流識別雜湊用祕密；正式環境請產生隨機值，不要提交。
GUARDAI_LIMIT_SALT=

# Upstash Redis／Vercel KV：只保存日期、不可逆訪客雜湊與使用次數。
KV_REST_API_URL=
KV_REST_API_TOKEN=
